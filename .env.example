# Database
# Для локальной SQLite:
# DATABASE_URL="file:./prisma/dev.db"
#
# Для Neon Tech (PostgreSQL):
# DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"
DATABASE_URL="postgresql://neondb_owner:npg_your_password@ep-your-endpoint-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Session
IRON_SESSION_PASSWORD="your-32-character-minimum-password-here-change-this"

# YouTube API (optional - for advanced features)
YOUTUBE_API_KEY="your-youtube-api-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (SMTP) - для функции сброса пароля
# Пример для Gmail:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# SMTP_FROM_EMAIL="your-email@gmail.com"

# Пример для Mailtrap (тестирование):
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="2525"
SMTP_SECURE="false"
SMTP_USER="your-mailtrap-username"
SMTP_PASSWORD="your-mailtrap-password"
SMTP_FROM_EMAIL="noreply@cs2smokes.com"
