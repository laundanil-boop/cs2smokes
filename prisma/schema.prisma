generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String               @id @default(cuid())
  email            String               @unique
  username         String               @unique
  password         String
  avatar           String?
  role             String               @default("user")
  banned           Boolean              @default(false)
  banReason        String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  referredByUserId String?
  comments         Comment[]
  favorites        Favorite[]
  lineups          Lineup[]
  resetTokens      PasswordResetToken[]
  premium          PremiumSubscription?
  referral         Referral?
  resolvedReports  Report[]             @relation("ReportResolver")
  reportedReports  Report[]             @relation("ReportReporter")
  sessions         Session[]
  referredByUser   User?                @relation("UserReferredUsers", fields: [referredByUserId], references: [id])
  referredUsers    User[]               @relation("UserReferredUsers")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Map {
  id             String           @id @default(cuid())
  name           String           @unique
  displayName    String
  imageUrl       String?
  description    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  positions      LineupPosition[]
  lineups        Lineup[]
  secretGrenades SecretGrenade[]
  tacticalRounds TacticalRound[]

  @@map("maps")
}

model LineupPosition {
  id          String   @id @default(cuid())
  name        String
  mapId       String
  imageUrl    String?
  positionX   Float
  positionY   Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  map         Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)
  lineups     Lineup[]

  @@index([mapId])
  @@map("lineup_positions")
}

model Lineup {
  id               String          @id @default(cuid())
  title            String
  description      String?
  mapId            String
  positionId       String?
  grenadeType      String
  side             String
  videoPath        String?
  youtubeId        String?
  thumbnailUrl     String?
  throwPosition    String?
  steps            String?
  difficulty       String          @default("MEDIUM")
  views            Int             @default(0)
  isUserGenerated  Boolean         @default(false)
  isPremium        Boolean         @default(false)
  moderationStatus String          @default("PENDING")
  rejectionReason  String?
  reviewedAt       DateTime?
  reviewedBy       String?
  userId           String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  comments         Comment[]
  favorites        Favorite[]
  tags             LineupTag[]
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  position         LineupPosition? @relation(fields: [positionId], references: [id])
  map              Map             @relation(fields: [mapId], references: [id], onDelete: Cascade)
  reports          Report[]

  @@index([mapId])
  @@index([grenadeType])
  @@index([userId])
  @@index([positionId])
  @@index([moderationStatus])
  @@map("lineups")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  lineupId  String
  createdAt DateTime @default(now())
  lineup    Lineup   @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lineupId])
  @@map("favorites")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  lineupId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lineup    Lineup   @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports   Report[]

  @@index([lineupId])
  @@map("comments")
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  createdAt DateTime    @default(now())
  lineups   LineupTag[]

  @@map("tags")
}

model LineupTag {
  lineupId String
  tagId    String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  lineup   Lineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)

  @@unique([lineupId, tagId])
  @@map("lineup_tags")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_reset_tokens")
}

model Report {
  id           String   @id @default(cuid())
  reason       String
  description  String?
  status       String   @default("PENDING")
  lineupId     String?
  commentId    String?
  reporterId   String?
  resolvedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resolvedBy   User?    @relation("ReportResolver", fields: [resolvedById], references: [id])
  reporter     User?    @relation("ReportReporter", fields: [reporterId], references: [id])
  comment      Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  lineup       Lineup?  @relation(fields: [lineupId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([lineupId])
  @@index([commentId])
  @@map("reports")
}

model PremiumSubscription {
  id        String    @id @default(cuid())
  userId    String    @unique
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("premium_subscriptions")
}

model TacticalRound {
  id           String   @id @default(cuid())
  title        String
  description  String?
  mapId        String
  side         String
  videoPath    String?
  youtubeId    String?
  thumbnailUrl String?
  steps        String?
  views        Int      @default(0)
  isPremium    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  map          Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@map("tactical_rounds")
}

model SecretGrenade {
  id            String   @id @default(cuid())
  title         String
  description   String?
  mapId         String
  grenadeType   String
  side          String
  videoPath     String?
  youtubeId     String?
  thumbnailUrl  String?
  throwPosition String?
  steps         String?
  views         Int      @default(0)
  isPremium     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  map           Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@map("secret_grenades")
}

model PromoCode {
  id        String           @id @default(cuid())
  code      String           @unique
  days      Int
  maxUses   Int?
  usedCount Int              @default(0)
  expiresAt DateTime?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  usages    PromoCodeUsage[]

  @@index([code])
  @@index([isActive])
  @@map("promo_codes")
}

model PromoCodeUsage {
  id          String    @id @default(cuid())
  promoCodeId String
  userId      String
  usedAt      DateTime  @default(now())
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([userId])
  @@map("promo_code_usages")
}

model BloggerPromoCode {
  id              String                  @id @default(cuid())
  code            String                  @unique
  bloggerUsername String
  days            Int
  maxUses         Int?
  usedCount       Int                     @default(0)
  expiresAt       DateTime?
  isActive        Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  usages          BloggerPromoCodeUsage[]

  @@index([code])
  @@index([bloggerUsername])
  @@index([isActive])
  @@map("blogger_promo_codes")
}

model BloggerPromoCodeUsage {
  id          String           @id @default(cuid())
  promoCodeId String
  userId      String
  usedAt      DateTime         @default(now())
  promoCode   BloggerPromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([userId])
  @@map("blogger_promo_code_usages")
}

model Referral {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String   @unique
  usesCount Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@map("referrals")
}

model ContactMessage {
  id         String    @id @default(cuid())
  name       String
  email      String
  subject    String
  message    String
  status     String    @default("PENDING")
  adminReply String?
  repliedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@map("contact_messages")
}
